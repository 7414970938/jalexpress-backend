# MongoDB Atlas connection string (free tier)
# Get this from mongodb.com/cloud/atlas after creating free cluster
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/jalexpress?retryWrites=true&w=majority

# JWT secret for auth tokens - use any long random string
JWT_SECRET=jalexpress_super_secret_key_change_this_in_production_123456

# Server port
PORT=5000

# Twilio (for OTP SMS - free trial credit available)
# Get from twilio.com after signup
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Environment
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
